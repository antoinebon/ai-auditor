# Copy to .env and adjust if your Ollama install is elsewhere.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Embedding model (runs locally via sentence-transformers; downloaded on first use).
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Paths (relative to repo root).
CONTROLS_PATH=data/controls/iso27001_annex_a.yaml
