# Copy to .env and adjust if your Ollama install is elsewhere.
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b-instruct

# Embedding model (runs locally via sentence-transformers; downloaded on first use).
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Paths (relative to repo root).
CONTROLS_PATH=data/controls/iso27001_annex_a.yaml

# MLflow tracking. Leave empty to use the local ``./mlruns`` file store
# (then run ``mlflow ui`` to view). Point at http://mlflow:5000 when
# running via docker compose.
MLFLOW_TRACKING_URI=
MLFLOW_EXPERIMENT=ai-auditor
